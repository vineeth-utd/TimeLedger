// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MainCategory {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid @map("user_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz @map("updated_at")

  subCategories SubCategory[]
  weeklyTargets WeeklyTarget[]

  @@unique([userId, name])
  @@index([userId])
  @@map("main_categories")
}

model SubCategory {
  id             Int      @id @default(autoincrement())
  userId         String   @db.Uuid @map("user_id")
  mainCategoryId Int      @map("main_category_id")
  name           String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime @updatedAt @db.Timestamptz @map("updated_at")

  mainCategory              MainCategory               @relation(fields: [mainCategoryId], references: [id], onDelete: Restrict)
  activities                Activity[]
  dailySubCategorySummaries DailySubCategorySummary[]

  @@unique([mainCategoryId, name])
  @@index([userId])
  @@index([mainCategoryId])
  @@map("sub_categories")
}

model Activity {
  id              Int      @id @default(autoincrement())
  userId          String   @db.Uuid @map("user_id")
  activityDate    DateTime @db.Date @map("activity_date")
  title           String
  subCategoryId   Int      @map("sub_category_id")
  startTime       DateTime @db.Timestamptz @map("start_time")
  endTime         DateTime @db.Timestamptz @map("end_time")
  durationMinutes Int      @map("duration_minutes")
  notes           String?
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([activityDate])
  @@index([subCategoryId])
  @@index([startTime])
  @@index([endTime])
  @@map("activities")
}

model DailySubCategorySummary {
  id              Int      @id @default(autoincrement())
  userId          String   @db.Uuid @map("user_id")
  summaryDate     DateTime @db.Date @map("summary_date")
  subCategoryId   Int      @map("sub_category_id")
  totalMinutes    Int      @map("total_minutes")
  totalActivities Int      @map("total_activities")
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)

  @@unique([userId, summaryDate, subCategoryId])
  @@index([userId])
  @@index([summaryDate])
  @@index([subCategoryId])
  @@map("daily_sub_category_summaries")
}

model WeeklyTarget {
  id             Int      @id @default(autoincrement())
  userId         String   @db.Uuid @map("user_id")
  weekStartDate  DateTime @db.Date @map("week_start_date")
  mainCategoryId Int      @map("main_category_id")
  targetMinutes  Int      @map("target_minutes")
  createdAt      DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime @updatedAt @db.Timestamptz @map("updated_at")

  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Restrict)

  @@unique([userId, weekStartDate, mainCategoryId])
  @@index([userId])
  @@index([weekStartDate])
  @@index([mainCategoryId])
  @@map("weekly_targets")
}
