// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz @map("updated_at")

  activities             Activity[]
  dailyCategorySummaries DailyCategorySummary[]
  weeklyTargets          WeeklyTarget[]

  @@map("categories")
}

model Activity {
  id              Int      @id @default(autoincrement())
  activityDate    DateTime @db.Date @map("activity_date")
  title           String
  categoryId      Int      @map("category_id")
  startTime       DateTime @db.Timestamptz @map("start_time")
  endTime         DateTime @db.Timestamptz @map("end_time")
  durationMinutes Int      @map("duration_minutes")
  notes           String?
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([activityDate])
  @@index([categoryId])
  @@index([startTime])
  @@index([endTime])
  @@map("activities")
}

model DailyCategorySummary {
  id              Int      @id @default(autoincrement())
  summaryDate     DateTime @db.Date @map("summary_date")
  categoryId      Int      @map("category_id")
  totalMinutes    Int      @map("total_minutes")
  totalActivities Int      @map("total_activities")
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([summaryDate, categoryId])
  @@index([summaryDate])
  @@index([categoryId])
  @@map("daily_category_summaries")
}

model WeeklyTarget {
  id            Int      @id @default(autoincrement())
  weekStartDate DateTime @db.Date @map("week_start_date")
  categoryId    Int      @map("category_id")
  targetMinutes Int      @map("target_minutes")
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime @updatedAt @db.Timestamptz @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([weekStartDate, categoryId])
  @@index([weekStartDate])
  @@index([categoryId])
  @@map("weekly_targets")
}
